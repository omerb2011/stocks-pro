      <div class="sent-val" style="color:${sentColor}">${sentLabel} ${s.sentiment}%</div>
    </div>

    <div class="fund-grid">
      <div class="fund-card">
        <div class="fund-label">שווי שוק</div>
        <div class="fund-val">$${s.mktCap}</div>
      </div>
      <div class="fund-card">
        <div class="fund-label">P/E</div>
        <div class="fund-val">${s.pe ?? 'N/A'}</div>
      </div>
      <div class="fund-card">
        <div class="fund-label">EPS</div>
        <div class="fund-val" style="color:${s.eps>0?'var(--green)':'var(--red)'}">$${s.eps}</div>
      </div>
      <div class="fund-card">
        <div class="fund-label">נפח מסחר</div>
        <div class="fund-val">${s.vol}</div>
      </div>
      <div class="fund-card">
        <div class="fund-label">52W גבוה / נמוך</div>
        <div class="fund-val" style="font-size:13px"><span class="pos">$${s.h52}</span> / <span class="neg">$${s.l52}</span></div>
      </div>
      <div class="fund-card">
        <div class="fund-label">רווח גולמי</div>
        <div class="fund-val">${s.gross}</div>
      </div>
      <div class="fund-card">
        <div class="fund-label">הכנסות שנתיות</div>
        <div class="fund-val">$${s.rev}</div>
      </div>
      <div class="fund-card">
        <div class="fund-label">דיבידנד</div>
        <div class="fund-val">${s.div}</div>
      </div>
      <div class="fund-card">
