<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>סקרינר מניות</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Noto+Sans+Hebrew:wght@300;400;500&display=swap');

:root {
  --bg: #07090f;
  --s1: #0d1117;
  --s2: #141b27;
  --s3: #1c2535;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.13);
  --text: #dde4f0;
  --muted: #556070;
  --muted2: #8a9ab5;
  --green: #10b981;
  --green2: rgba(16,185,129,0.15);
  --red: #ef4444;
  --red2: rgba(239,68,68,0.15);
  --amber: #f59e0b;
  --amber2: rgba(245,158,11,0.15);
  --cyan: #22d3ee;
  --cyan2: rgba(34,211,238,0.1);
  --indigo: #818cf8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Noto Sans Hebrew', sans-serif;
  min-height: 100vh;
  direction: rtl;
  overflow-x: hidden;
}

/* HEADER */
.header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 24px;
  border-bottom: 1px solid var(--border);
  background: rgba(7,9,15,0.97);
  position: sticky;
  top: 0;
  z-index: 200;
  backdrop-filter: blur(12px);
}

.brand {
  font-family: 'Syne', sans-serif;
  font-size: 18px;
  font-weight: 800;
  color: var(--cyan);
  letter-spacing: -0.5px;
  white-space: nowrap;
  flex-shrink: 0;
}

.brand span { color: var(--muted2); font-weight: 400; }

.search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  max-width: 400px;
  background: var(--s2);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 0 12px;
  transition: border-color 0.2s;
}

.search-wrap:focus-within { border-color: var(--cyan); }

.search-wrap input {
  background: none;
  border: none;
  outline: none;
  color: var(--text);
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  padding: 9px 0;
  width: 100%;
  direction: ltr;
}

.search-wrap input::placeholder { color: var(--muted); }

.search-ico { color: var(--muted); font-size: 14px; }

.add-btn {
  background: var(--cyan);
  border: none;
  border-radius: 8px;
  padding: 8px 16px;
  color: #07090f;
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.add-btn:hover { background: #67e8f9; transform: translateY(-1px); }
.add-btn:active { transform: scale(0.97); }

.alert-btn {
  background: var(--s2);
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 8px 14px;
  color: var(--amber);
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
  position: relative;
}
.alert-btn:hover { border-color: var(--amber); }

.alert-badge {
  position: absolute;
  top: -5px;
  left: -5px;
  background: var(--amber);
  color: #07090f;
  font-size: 9px;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'JetBrains Mono', monospace;
}

/* LAYOUT */
.layout {
  display: grid;
  grid-template-columns: 340px 1fr;
  height: calc(100vh - 53px);
}

/* SIDEBAR */
.sidebar {
  border-left: 1px solid var(--border);
  overflow-y: auto;
  overflow-x: hidden;
  background: var(--s1);
}

.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: var(--s3); border-radius: 2px; }

.sidebar-head {
  padding: 14px 16px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  background: var(--s1);
  z-index: 10;
  border-bottom: 1px solid var(--border);
}

.label-xs {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--muted);
}

.count-badge {
  background: var(--s3);
  border-radius: 20px;
  padding: 2px 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--muted2);
}

.stock-row {
  display: grid;
  grid-template-columns: 1fr auto;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.15s;
  position: relative;
  gap: 8px;
  align-items: center;
}

.stock-row:hover { background: var(--s2); }
.stock-row.active { background: var(--s3); }
.stock-row.active::before {
  content: '';
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 2px;
  background: var(--cyan);
}

.stock-row-left { min-width: 0; }

.row-ticker {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 6px;
}

.alert-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--amber);
  flex-shrink: 0;
}

.row-name {
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.row-right { text-align: left; }

.row-price {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 500;
}

.row-chg {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  margin-top: 2px;
  text-align: left;
}

.row-del {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 0;
  background: var(--red2);
  overflow: hidden;
  transition: width 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.stock-row:hover .row-del { width: 36px; }
.row-del span { color: var(--red); font-size: 16px; }

/* MAIN CONTENT */
.main-content {
  overflow-y: auto;
  background: var(--bg);
  padding: 24px;
}

.main-content::-webkit-scrollbar { width: 4px; }
.main-content::-webkit-scrollbar-track { background: transparent; }
.main-content::-webkit-scrollbar-thumb { background: var(--s3); border-radius: 2px; }

.empty-main {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  color: var(--muted);
}

.empty-icon { font-size: 48px; }
.empty-main p { font-size: 14px; }

/* DETAIL */
.detail-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 16px;
}

.detail-left h1 {
  font-family: 'Syne', sans-serif;
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 4px;
}

.detail-left .sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--muted2);
  display: flex;
  gap: 12px;
  align-items: center;
}

.tag {
  background: var(--s2);
  border: 1px solid var(--border2);
  border-radius: 5px;
  padding: 2px 8px;
  font-size: 10px;
  color: var(--muted2);
  font-family: 'JetBrains Mono', monospace;
}

.detail-right { text-align: left; }

.big-price {
  font-family: 'JetBrains Mono', monospace;
  font-size: 34px;
  font-weight: 700;
  line-height: 1;
}

.big-chg {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  margin-top: 5px;
  text-align: left;
  display: flex;
  align-items: center;
  gap: 6px;
  justify-content: flex-end;
}

.chg-pill {
  border-radius: 5px;
  padding: 2px 8px;
  font-size: 11px;
  font-family: 'JetBrains Mono', monospace;
}

/* FUNDAMENTALS GRID */
.fund-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}

.fund-card {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 14px;
  transition: border-color 0.2s;
}

.fund-card:hover { border-color: var(--border2); }

.fund-label {
  font-size: 10px;
  color: var(--muted);
  margin-bottom: 6px;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.5px;
}

.fund-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 16px;
  font-weight: 700;
}

/* CHART PANEL */
.chart-panel {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 16px 10px;
  margin-bottom: 20px;
}

.chart-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
  direction: ltr;
}

.range-group { display: flex; gap: 4px; }

.rtab {
  background: none;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 4px 10px;
  color: var(--muted);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  cursor: pointer;
  transition: all 0.15s;
}

.rtab.active, .rtab:hover {
  background: var(--cyan2);
  border-color: var(--cyan);
  color: var(--cyan);
}

.chart-stats {
  display: flex;
  gap: 16px;
  direction: ltr;
}

.cstat { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--muted2); }
.cstat span { color: var(--text); font-weight: 500; }

.chart-box { height: 220px; position: relative; }

/* ALERTS PANEL */
.alerts-panel {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 20px;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.panel-title {
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8px;
}

.add-alert-form {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.add-alert-form select,
.add-alert-form input {
  background: var(--s2);
  border: 1px solid var(--border2);
  border-radius: 7px;
  color: var(--text);
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  padding: 7px 10px;
  outline: none;
  transition: border-color 0.2s;
}

.add-alert-form select:focus,
.add-alert-form input:focus { border-color: var(--amber); }

.add-alert-form input[type=number] { width: 100px; direction: ltr; }

.mini-btn {
  background: var(--amber2);
  border: 1px solid var(--amber);
  border-radius: 7px;
  padding: 7px 12px;
  color: var(--amber);
  font-family: 'Syne', sans-serif;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.15s;
}

.mini-btn:hover { background: var(--amber); color: #07090f; }

.alerts-list { display: flex; flex-direction: column; gap: 8px; }

.alert-item {
  background: var(--s2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.alert-item.triggered {
  border-color: var(--amber);
  background: var(--amber2);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0.4); }
  50% { box-shadow: 0 0 0 6px rgba(245,158,11,0); }
}

.alert-info { display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; }

.alert-type-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  padding: 3px 7px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}

.badge-above { background: var(--green2); color: var(--green); border: 1px solid var(--green); }
.badge-below { background: var(--red2); color: var(--red); border: 1px solid var(--red); }

.alert-desc {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--muted2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.alert-desc strong { color: var(--text); }

.del-alert {
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: 14px;
  padding: 2px 5px;
  border-radius: 4px;
  transition: all 0.15s;
  flex-shrink: 0;
}

.del-alert:hover { background: var(--red2); color: var(--red); }

.triggered-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--amber);
  font-weight: 700;
  flex-shrink: 0;
}

/* NEWS */
.news-panel {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px;
}

.news-item {
  display: flex;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

.news-item:last-child { border-bottom: none; padding-bottom: 0; }
.news-item:first-child { padding-top: 0; }

.news-src {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  color: var(--cyan);
  letter-spacing: 1px;
  white-space: nowrap;
  width: 50px;
  flex-shrink: 0;
  padding-top: 2px;
}

.news-body {}

.news-title {
  font-size: 13px;
  line-height: 1.5;
  margin-bottom: 3px;
  color: var(--text);
}

.news-time {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--muted);
}

/* SENTIMENT BAR */
.sentiment-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 14px;
}

.sent-label { font-size: 11px; color: var(--muted); white-space: nowrap; }

.sent-track {
  flex: 1;
  height: 6px;
  background: var(--s3);
  border-radius: 3px;
  overflow: hidden;
}

.sent-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.5s;
}

.sent-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  white-space: nowrap;
}

/* MODAL */
.modal-bg {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 500;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.modal-bg.open { display: flex; }

.modal {
  background: var(--s1);
  border: 1px solid var(--border2);
  border-radius: 16px;
  padding: 24px;
  width: 90%;
  max-width: 480px;
  max-height: 80vh;
  overflow-y: auto;
}

.modal h3 {
  font-family: 'Syne', sans-serif;
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.all-alerts-list { display: flex; flex-direction: column; gap: 8px; }

.modal-close {
  display: block;
  margin-top: 16px;
  background: none;
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 8px;
  color: var(--muted2);
  cursor: pointer;
  font-family: 'Noto Sans Hebrew', sans-serif;
  font-size: 13px;
  width: 100%;
}

.modal-close:hover { border-color: var(--text); color: var(--text); }

/* TOAST */
.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--s2);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 10px 20px;
  font-size: 13px;
  opacity: 0;
  transition: all 0.3s;
  z-index: 999;
  pointer-events: none;
  white-space: nowrap;
}

.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

.pos { color: var(--green); }
.neg { color: var(--red); }

@media (max-width: 768px) {
  .layout { grid-template-columns: 1fr; grid-template-rows: 200px 1fr; }
  .sidebar { border-left: none; border-bottom: 1px solid var(--border); }
  .fund-grid { grid-template-columns: repeat(2,1fr); }
  .header { flex-wrap: wrap; gap: 8px; }
}
</style>
</head>
<body>

<div class="header">
  <div class="brand">SCREENER<span>.PRO</span></div>
  <div class="search-wrap">
    <span class="search-ico">⌕</span>
    <input type="text" id="searchInput" placeholder="הוסף מניה: AAPL, TSLA, NVDA..." />
  </div>
  <button class="add-btn" onclick="addStock()">+ הוסף</button>
  <button class="alert-btn" onclick="openAlertsModal()">
    🔔 התראות
    <div class="alert-badge" id="alertBadge" style="display:none">0</div>
  </button>
</div>

<div class="layout">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-head">
      <span class="label-xs">מעקב</span>
      <span class="count-badge" id="countBadge">0</span>
    </div>
    <div id="stockList"></div>
  </div>

  <!-- MAIN -->
  <div class="main-content" id="mainContent">
    <div class="empty-main" id="emptyState">
      <div class="empty-icon">📊</div>
      <p>בחר מניה מהרשימה לצפייה בפרטים</p>
      <p style="font-size:12px; color: var(--muted); margin-top:4px">AAPL, MSFT, NVDA, TSLA, AMZN, META, GOOGL...</p>
    </div>
    <div id="detailContent" style="display:none"></div>
  </div>
</div>

<!-- ALERTS MODAL -->
<div class="modal-bg" id="alertsModal" onclick="if(event.target===this)closeAlertsModal()">
  <div class="modal">
    <h3>🔔 כל ההתראות</h3>
    <div class="all-alerts-list" id="allAlertsList"></div>
    <button class="modal-close" onclick="closeAlertsModal()">סגור</button>
  </div>
</div>

<div class="toast" id="toast"></div>

