let alerts = []; // { id, ticker, type:'above'|'below', price, triggered }
let alertIdCounter = 1;

function generateData(ticker, range) {
  const base = DB[ticker]?.price || 100;
  const pts = {  '1D':48, '1W':7, '1M':30, '3M':90, '1Y':252 }[range];
  const vols = { '1D':0.005, '1W':0.015, '3M':0.025, '1Y':0.03, '1M':0.02 }[range];
  const seed = ticker.charCodeAt(0) + ticker.charCodeAt(1);
  const data = [];
  let p = base * (0.88 + (seed % 20) * 0.01);
  for (let i = 0; i < pts; i++) {
    const rnd = Math.sin(i * seed * 0.37) * 0.5 + (Math.random() - 0.48);
    p *= (1 + rnd * vols);
    data.push(+p.toFixed(2));
  }
  data[data.length - 1] = base;
  return data;
}

function generateLabels(range) {
  const pts = { '1D':48, '1W':7, '1M':30, '3M':90, '1Y':252 }[range];
  const daysBack = { '1D':1, '1W':7, '1M':30, '3M':90, '1Y':365 }[range];
  const labels = [];
  const now = new Date();
  for (let i = pts-1; i >= 0; i--) {
    const d = new Date(now - i * (daysBack/pts) * 86400000);
    if (range === '1D') labels.push(d.getHours()+':00');
    else if (range === '1Y') labels.push(d.toLocaleDateString('en',{month:'short',year:'2-digit'}));
    else labels.push(d.toLocaleDateString('en',{month:'short',day:'numeric'}));
  }
  return labels;
}

function renderSidebar() {
  const list = document.getElementById('stockList');
  document.getElementById('countBadge').textContent = watchlist.length;
  if (watchlist.length === 0) {
    list.innerHTML = '<div style="padding:24px;text-align:center;color:var(--muted);font-size:13px">הוסף מניה לרשימה</div>';
    return;
  }
  list.innerHTML = watchlist.map(t => {
    const s = DB[t];
    if (!s) return '';
    const pos = s.change >= 0;
    const hasAlerts = alerts.some(a => a.ticker === t);
    return `<div class="stock-row ${selected===t?'active':''}" onclick="selectStock('${t}')">
      <div class="row-del" onclick="event.stopPropagation();removeStock('${t}')"><span>✕</span></div>
      <div class="stock-row-left">
        <div class="row-ticker">${t} ${hasAlerts?'<div class="alert-dot"></div>':''}</div>
        <div class="row-name">${s.name}</div>
      </div>
      <div class="row-right">
        <div class="row-price">$${s.price.toFixed(2)}</div>
        <div class="row-chg ${pos?'pos':'neg'}">${pos?'+':''}${s.change}%</div>
      </div>
    </div>`;
  }).join('');
}

function selectStock(ticker) {
  selected = ticker;
  renderSidebar();
  renderDetail();
}

