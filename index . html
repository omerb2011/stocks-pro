          ${['1D','1W','1M','3M','1Y'].map(r=>`<button class="rtab ${r===currentRange?'active':''}" onclick="setRange('${r}',this)">${r}</button>`).join('')}
        </div>
      </div>
      <div class="chart-box"><canvas id="priceChart"></canvas></div>
    </div>

    <div class="alerts-panel">
      <div class="panel-head">
        <div class="panel-title">🔔 התראות מחיר <span style="font-family:JetBrains Mono,monospace;color:var(--cyan);font-size:12px">${selected}</span></div>
      </div>
      <div class="add-alert-form">
        <select id="alertType">
          <option value="above">מעל ▲</option>
          <option value="below">מתחת ▼</option>
        </select>
        <input type="number" id="alertPrice" placeholder="${s.price.toFixed(0)}" step="0.01" />
        <button class="mini-btn" onclick="addAlert()">+ הוסף התראה</button>
      </div>
      <div class="alerts-list" id="alertsList">
        ${tickerAlerts.length === 0 ? '<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px">אין התראות פעילות</div>' : ''}
      </div>
    </div>

    <div class="news-panel">
      <div class="panel-head">
        <div class="panel-title">📰 חדשות אחרונות</div>
      </div>
      ${news.map(n=>`
        <div class="news-item">
          <div class="news-src">${n.src}</div>
          <div class="news-body">
            <div class="news-title">${n.title}</div>
            <div class="news-time">${n.time}</div>
          </div>
        </div>
      `).join('')}
    </div>
  `;

  renderAlertsList();
  drawChart();
}

function drawChart() {
  if (chart) { chart.destroy(); chart = null; }
  const canvas = document.getElementById('priceChart');
  if (!canvas) return;
  const s = DB[selected];
  const data = generateData(selected, currentRange);
  const labels = generateLabels(currentRange);
  const isUp = data[data.length-1] >= data[0];
  const color = isUp ? '#10b981' : '#ef4444';

  const ctx = canvas.getContext('2d');
  const grad = ctx.createLinearGradient(0,0,0,220);
  grad.addColorStop(0, isUp ? 'rgba(16,185,129,0.25)' : 'rgba(239,68,68,0.25)');
  grad.addColorStop(1, 'rgba(0,0,0,0)');

  chart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets: [{ data, borderColor:color, borderWidth:1.5, backgroundColor:grad, fill:true, tension:0.4, pointRadius:0, pointHoverRadius:3, pointHoverBackgroundColor:color }] },
    options: {
      responsive:true, maintainAspectRatio:false,
      interaction:{ intersect:false, mode:'index' },
      plugins: {
        legend:{ display:false },
        tooltip:{
          backgroundColor:'#141b27', borderColor:'rgba(255,255,255,0.1)', borderWidth:1,
          titleColor:'#556070', bodyColor:'#dde4f0',
          bodyFont:{ family:"'JetBrains Mono', monospace", size:12 },
          titleFont:{ size:10 },
          callbacks:{ label: ctx=>'$'+ctx.raw.toFixed(2) }
        }
      },
      scales:{
        x:{ ticks:{ color:'#556070', font:{size:10}, maxTicksLimit:6 }, grid:{ color:'rgba(255,255,255,0.04)' }, border:{ display:false } },
        y:{ position:'right', ticks:{ color:'#556070', font:{family:"'JetBrains Mono',monospace",size:10}, callback:v=>'$'+v.toFixed(0) }, grid:{ color:'rgba(255,255,255,0.04)' }, border:{ display:false } }
      }
    }
  });
}

function setRange(r, btn) {
  currentRange = r;
  document.querySelectorAll('.rtab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawChart();
}

function addAlert() {
  const type = document.getElementById('alertType').value;
  const price = parseFloat(document.getElementById('alertPrice').value);
  if (!price || isNaN(price)) { showToast('הכנס מחיר תקין'); return; }
  alerts.push({ id: alertIdCounter++, ticker: selected, type, price, triggered: false });
  document.getElementById('alertPrice').value = '';
  renderAlertsList();
  updateAlertBadge();
  showToast(`✓ התראה נוספה: ${selected} ${type==='above'?'מעל':'מתחת'} $${price}`);
  checkAlerts();
}

function renderAlertsList() {
  const el = document.getElementById('alertsList');
  if (!el) return;
  const tickerAlerts = alerts.filter(a => a.ticker === selected);
  if (tickerAlerts.length === 0) {
    el.innerHTML = '<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px">אין התראות פעילות</div>';
    return;
  }
  el.innerHTML = tickerAlerts.map(a => `
    <div class="alert-item ${a.triggered?'triggered':''}">
      <div class="alert-info">
        <span class="alert-type-badge ${a.type==='above'?'badge-above':'badge-below'}">${a.type==='above'?'▲ מעל':'▼ מתחת'}</span>
        <span class="alert-desc"><strong>$${a.price.toFixed(2)}</strong> · נוכחי: $${DB[selected].price.toFixed(2)}</span>
      </div>
      ${a.triggered ? '<span class="triggered-label">⚡ הופעל</span>' : ''}
      <button class="del-alert" onclick="deleteAlert(${a.id})">✕</button>
    </div>
  `).join('');
}

function deleteAlert(id) {
  alerts = alerts.filter(a => a.id !== id);
  renderAlertsList();
  renderSidebar();
  updateAlertBadge();
}

function checkAlerts() {
  alerts.forEach(a => {
    const s = DB[a.ticker];
    if (!s) return;
    const oldTriggered = a.triggered;
    if (a.type === 'above' && s.price >= a.price) a.triggered = true;
    if (a.type === 'below' && s.price <= a.price) a.triggered = true;
    if (a.triggered && !oldTriggered) {
      showToast(`🔔 התראה: ${a.ticker} ${a.type==='above'?'עברה מעל':'ירדה מתחת'} $${a.price}`);
    }
  });
  if (selected) renderAlertsList();
  updateAlertBadge();
  renderSidebar();
}

function updateAlertBadge() {
  const badge = document.getElementById('alertBadge');
  const n = alerts.length;
  badge.style.display = n > 0 ? 'flex' : 'none';
  badge.textContent = n;
}

function openAlertsModal() {
  const modal = document.getElementById('alertsModal');
  const list = document.getElementById('allAlertsList');
  modal.classList.add('open');
  if (alerts.length === 0) {
    list.innerHTML = '<div style="text-align:center;color:var(--muted);font-size:13px;padding:20px">אין התראות פעילות</div>';
    return;
  }
  list.innerHTML = alerts.map(a => `
    <div class="alert-item ${a.triggered?'triggered':''}">
      <div class="alert-info">
        <span class="alert-type-badge ${a.type==='above'?'badge-above':'badge-below'}">${a.type==='above'?'▲':'▼'}</span>
        <span class="alert-desc"><strong>${a.ticker}</strong> ${a.type==='above'?'מעל':'מתחת'} $${a.price.toFixed(2)}</span>
      </div>
      ${a.triggered ? '<span class="triggered-label">⚡ הופעל</span>' : ''}
      <button class="del-alert" onclick="deleteAlert(${a.id});openAlertsModal()">✕</button>
    </div>
  `).join('');
}

function closeAlertsModal() {
  document.getElementById('alertsModal').classList.remove('open');
}

function addStock() {
  const input = document.getElementById('searchInput');
  const ticker = input.value.trim().toUpperCase();
  if (!ticker) return;
  if (!DB[ticker]) { showToast('מניה לא נמצאה. נסה: AAPL, MSFT, NVDA...'); return; }
  if (watchlist.includes(ticker)) { showToast('המניה כבר ברשימה'); selectStock(ticker); return; }
  watchlist.push(ticker);
  input.value = '';
  renderSidebar();
  selectStock(ticker);
  showToast('✓ ' + ticker + ' נוסף לרשימה');
}

function removeStock(ticker) {
  watchlist = watchlist.filter(t => t !== ticker);
  if (selected === ticker) {
    selected = null;
    document.getElementById('emptyState').style.display = 'flex';
    document.getElementById('detailContent').style.display = 'none';
  }
  renderSidebar();
}

function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 3000);
}

document.getElementById('searchInput').addEventListener('keydown', e => { if(e.key==='Enter') addStock(); });

// Simulate live price updates
setInterval(() => {
  Object.keys(DB).forEach(t => {
    const s = DB[t];
    const delta = (Math.random() - 0.5) * 0.04;
    s.price = +(s.price * (1 + delta * 0.01)).toFixed(2);
  });
  renderSidebar();
  if (selected) {
    const s = DB[selected];
    const el = document.querySelector('.big-price');
    if (el) {
      const pos = s.change >= 0;
      el.textContent = '$' + s.price.toFixed(2);
      el.style.color = pos ? 'var(--green)' : 'var(--red)';
    }
  }
  checkAlerts();
}, 4000);

// init
renderSidebar();
selectStock('NVDA');
</script>
