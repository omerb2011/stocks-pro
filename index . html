        </div>
      </div>
      <div class="detail-right">
        <div class="big-price" style="color:${pos?'var(--green)':'var(--red)'}">$${s.price.toFixed(2)}</div>
        <div class="big-chg">
          <span class="chg-pill" style="background:${pos?'var(--green2)':'var(--red2)'};color:${pos?'var(--green)':'var(--red)'}">${pos?'▲':'▼'} ${Math.abs(s.change)}%</span>
